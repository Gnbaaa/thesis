# --- Ерөнхий ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# --- CORS (frontend URL, олон бол таслалаар) ---
CORS_ORIGIN=http://localhost:5173

# --- Өгөгдлийн сан ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pet_platform
MONGODB_URL=mongodb://localhost:27017/pet_platform
REDIS_URL=redis://localhost:6379

# --- JWT ---
JWT_SECRET=change-me-to-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Google OAuth2 (хоосон бол нэвтрэхгүй) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:4000/auth/google/callback

# --- Stripe (test sandbox) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
