# Backend API (REST)
VITE_API_URL=http://localhost:4000

# WebSocket (чат) — backend-тай ижил host, ws/wss
VITE_WS_URL=ws://localhost:4000

# Stripe publishable key (зөвхөн frontend, test)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Cloudinary cloud name (зураг upload widget эсвэл public URL-д)
VITE_CLOUDINARY_CLOUD_NAME=
